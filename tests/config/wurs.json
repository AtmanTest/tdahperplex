{
  "id": "wurs",
  "title": "WURS-61",
  "fullName": "Wender Utah Rating Scale",
  "description": "Évaluation rétrospective des symptômes du TDAH pendant l'enfance (5-12 ans). Permet de confirmer le caractère développemental du trouble.",
  "type": "self-report",
  "reference": "Ward MF, Wender PH, Reimherr FW (1993). The Wender Utah Rating Scale: an aid in the retrospective diagnosis of childhood attention deficit hyperactivity disorder.",
  "license": "Libre d'utilisation clinique",
  "durationMin": 12,
  "hasReversedItems": true,
  "sections": [
    { "id": "childhood", "title": "Enfance (5-12 ans)", "instruction": "Pour chaque item, indiquez à quel point la description correspond à ce que vous étiez étant enfant (entre 5 et 12 ans)." },
    { "id": "medical", "title": "Problèmes médicaux pendant l'enfance", "instruction": "Indiquez si vous avez eu ces problèmes étant enfant." },
    { "id": "school", "title": "À l'école", "instruction": "Indiquez à quel point ces descriptions correspondent à votre parcours scolaire." }
  ],
  "items": [
    { "id": "wurs-1", "section": "childhood", "text": "Actif(ve), agité(e), toujours à courir", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-2", "section": "childhood", "text": "Peur des choses", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-3", "section": "childhood", "text": "Des problèmes de concentration, facilement distrait(e)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-4", "section": "childhood", "text": "Anxieux(se), se faisant du souci", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-5", "section": "childhood", "text": "Nerveux(se), ne tenant pas en place", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-6", "section": "childhood", "text": "Inattentif(ve), rêveur(se)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-7", "section": "childhood", "text": "Facilement en colère, soupe au lait", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-8", "section": "childhood", "text": "Timide, sensible", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-9", "section": "childhood", "text": "Des éclats d'humeur, des accès de colère", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-10", "section": "childhood", "text": "Des difficultés à mener mes projets jusqu'au bout, à finir les choses commencées", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-11", "section": "childhood", "text": "Têtu(e), obstiné(e)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-12", "section": "childhood", "text": "Triste ou cafardeux(se), déprimé(e), malheureux(se)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-13", "section": "childhood", "text": "Imprudent(e), casse-cou, faisant les quatre cents coups", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-14", "section": "childhood", "text": "Ne prenant pas plaisir à faire des choses, insatisfait(e) de la vie", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-15", "section": "childhood", "text": "Désobéissant(e) à mes parents, rebelle, effronté(e)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-16", "section": "childhood", "text": "Une mauvaise opinion de moi-même", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-17", "section": "childhood", "text": "Irritable", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-18", "section": "childhood", "text": "Sociable, amical(e), prenant plaisir à la compagnie des autres", "reversed": true, "invertNote": "item inversé (4 → 0)", "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-19", "section": "childhood", "text": "Négligent(e), désordonné(e)", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-20", "section": "childhood", "text": "D'humeur changeante, avec des hauts et des bas", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-21", "section": "childhood", "text": "En colère", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-22", "section": "childhood", "text": "Des amis, populaire", "reversed": true, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-23", "section": "childhood", "text": "Bien organisé(e), ordonné(e), soigné(e)", "reversed": true, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-24", "section": "childhood", "text": "Impulsif(ve), agissant sans réfléchir", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
