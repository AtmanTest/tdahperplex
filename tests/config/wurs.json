    { "id": "wurs-27", "section": "childhood", "text": "Une perte de contrôle de moi-même", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
    { "id": "wurs-28", "section": "childhood", "text": "Tendance à être ou à agir de façon irrationnelle", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
