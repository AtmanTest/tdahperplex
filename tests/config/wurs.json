    { "id": "wurs-31", "section": "childhood", "text": "Effrayé(e) de perdre le contrôle de moi-même", "reversed": false, "options": [{ "label": "Pas du tout", "value": 0 }, { "label": "Légèrement", "value": 1 }, { "label": "Modérément", "value": 2 }, { "label": "Assez", "value": 3 }, { "label": "Beaucoup", "value": 4 }] },
